format_version: 1

components:
  - name: Guides
    slug: guides
    repo: https://github.com/bluesky-social/atproto-website
    push: https://github.com/bluesky-social/atproto-website
    source_language: en
    filemask: src/app/*/guides/*/{{ language_code }}.mdx
    template: src/app/*/guides/*/en.mdx
    file_format: markdownl10n
    new_base: ""
    language_regex: "^(en|ja|ko|pt)$"
    push_on_commit: false
    commit_pending_age: 24
    check_flags: "ignore-xml-invalid"
